# Database Configuration
# Required: PostgreSQL connection string
# Format: postgres://[user]:[password]@[host]:[port]/[database]?[options]
DATABASE_URL=postgres://postgres:password@localhost:5432/byos_db?sslmode=disable

# Public Base URL (Optional)
# Absolute URL where this instance is reachable, e.g. https://byos.example.com
# Used for absolute metadata/Open Graph URLs and the browser renderer.
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_BASE_URL=

# React Renderer Configuration
# Options: "takumi" (default) or "satori" or "browser"
# Controls which rendering engine is used for screen generation
REACT_RENDERER=takumi

# Debug Mode
# Set to "true" to enable debug logging
DEBUG=false

# Node Environment
# Options: "development" or "production"
NODE_ENV=development

# Wikipedia API (Optional)
# Access token for Wikipedia API requests
WIKIPEDIA_ACCESS_TOKEN=

# Wikipedia Cache (Optional)
# Set to "true" to force using Reservoir cache for Wikipedia data
FORCE_WIKIPEDIA_RESERVOIR=false

# Authentication
# Set to "false" to disable authentication (mono-user mode)
AUTH_ENABLED=true
BETTER_AUTH_SECRET=your_better_auth_secret_32_characters_min
# The first account created during setup becomes admin automatically.

# TRMNL Live Proxy (Optional)
# By default the read-only TRMNL endpoints (/api/models, /api/palettes,
# /api/categories, /api/ips, /api/markup) are served from a local 24h cache
# seeded by data/trmnl/*.json so the app works offline. Set to "true" to
# bypass the cache and proxy every request to https://usetrmnl.com.
TRMNL_PROXY_LIVE=false

# External Catalog (Optional)
# Set to "true" to allow the server to fetch the community recipe catalog
# (GitHub raw YAML) and the TRMNL official recipes API. When disabled (default),
# the /catalog page shows an empty-state message and recipe installation is
# blocked server-side.
ENABLE_EXTERNAL_CATALOG=false