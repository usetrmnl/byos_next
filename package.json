{
	"name": "byos-nextjs",
	"version": "0.2.0",
	"private": true,
	"scripts": {
		"screenshots": "node scripts/take-screenshots.mjs",
		"generate:sql": "node scripts/generate-sql-statements.js && pnpm format",
		"generate:types": "kysely-codegen --dialect postgres --include-pattern='public.*' --out-file lib/database/db.d.ts",
		"prebuild": "pnpm generate:sql",
		"dev": "pnpm generate:sql && next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "biome check ./app ./components ./lib ./utils ./hooks",
		"lint:fix": "biome check --write --unsafe ./app ./components ./lib ./utils ./hooks",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write ./app ./components ./lib ./utils ./hooks",
		"release:major": "pnpm version major -m 'chore(release): %s' && git push --follow-tags",
		"release:minor": "pnpm version minor -m 'chore(release): %s' && git push --follow-tags",
		"release:patch": "pnpm version patch -m 'chore(release): %s' && git push --follow-tags"
	},
	"dependencies": {
		"@radix-ui/react-aspect-ratio": "^1.1.8",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-progress": "^1.1.8",
		"@radix-ui/react-scroll-area": "^1.2.10",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slider": "^1.3.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-switch": "^1.2.6",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-toggle": "^1.1.10",
		"@radix-ui/react-toggle-group": "^1.1.11",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@redux-devtools/extension": "^4.0.0",
		"@sparticuz/chromium-min": "^147.0.2",
		"@takumi-rs/core": "^1.1.2",
		"@takumi-rs/helpers": "^1.1.2",
		"@takumi-rs/wasm": "^1.1.2",
		"@tanstack/react-virtual": "^3.13.24",
		"@types/d3": "^7.4.3",
		"better-auth": "^1.6.9",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "1.1.1",
		"d3": "^7.9.0",
		"jimp": "^1.6.1",
		"js-yaml": "^4.1.1",
		"jszip": "^3.10.1",
		"kysely": "^0.28.16",
		"liquidjs": "^10.25.7",
		"lucide-react": "^1.11.0",
		"next": "16.2.4",
		"next-themes": "^0.4.6",
		"pg": "^8.20.0",
		"postgres": "^3.4.9",
		"puppeteer-core": "^24.42.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-virtuoso": "^4.18.6",
		"satori": "^0.26.0",
		"sharp": "^0.34.5",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tailwindcss-animate": "^1.0.7",
		"zod": "^4.3.6",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.13",
		"@eslint/eslintrc": "^3.3.5",
		"@tailwindcss/postcss": "^4.2.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.6.0",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"baseline-browser-mapping": "^2.10.21",
		"eslint": "^9.39.2",
		"eslint-config-next": "16.1.6",
		"eslint-plugin-react-hooks": "^7.0.1",
		"kysely-codegen": "^0.20.0",
		"shadcn": "^4.4.0",
		"tailwindcss": "^4.2.4",
		"typescript": "^6.0.3"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"@tailwindcss/oxide",
			"unrs-resolver"
		]
	}
}