{
	"name": "byos-nextjs",
	"version": "0.2.15",
	"private": true,
	"engines": {
		"node": "22.22.3",
		"pnpm": "11.8.0"
	},
	"scripts": {
		"test": "jest",
		"screenshots": "node scripts/take-screenshots.mjs",
		"generate:sql": "node scripts/generate-sql-statements.js && pnpm format",
		"generate:types": "kysely-codegen --dialect postgres --include-pattern='public.*' --out-file lib/database/db.d.ts",
		"generate:types:trmnl": "openapi-typescript lib/trmnl/openapi.yaml -o lib/trmnl/types.gen.ts && biome format --write lib/trmnl/types.gen.ts",
		"generate:recipes": "node scripts/generate-recipes-index.mjs && biome format --write lib/recipes/screens.generated.ts",
		"prebuild": "pnpm generate:sql && pnpm generate:recipes",
		"dev": "pnpm generate:sql && pnpm generate:recipes && next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"lint": "biome check ./app ./components ./lib ./utils ./hooks",
		"lint:fix": "biome check --write --unsafe ./app ./components ./lib ./utils ./hooks",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write ./app ./components ./lib ./utils ./hooks",
		"release:major": "pnpm version major -m 'chore(release): %s' && git push --follow-tags",
		"release:minor": "pnpm version minor -m 'chore(release): %s' && git push --follow-tags",
		"release:patch": "pnpm version patch -m 'chore(release): %s' && git push --follow-tags"
	},
	"dependencies": {
		"@radix-ui/react-aspect-ratio": "^1.1.10",
		"@radix-ui/react-avatar": "^1.2.0",
		"@radix-ui/react-collapsible": "^1.1.14",
		"@radix-ui/react-dialog": "^1.1.17",
		"@radix-ui/react-dropdown-menu": "^2.1.18",
		"@radix-ui/react-label": "^2.1.10",
		"@radix-ui/react-popover": "^1.1.17",
		"@radix-ui/react-progress": "^1.1.10",
		"@radix-ui/react-scroll-area": "^1.2.12",
		"@radix-ui/react-select": "^2.3.1",
		"@radix-ui/react-separator": "^1.1.10",
		"@radix-ui/react-slider": "^1.4.1",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-switch": "^1.3.1",
		"@radix-ui/react-tabs": "^1.1.15",
		"@radix-ui/react-toggle": "^1.1.12",
		"@radix-ui/react-toggle-group": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.10",
		"@redux-devtools/extension": "^4.0.0",
		"@sparticuz/chromium-min": "^149.0.0",
		"@takumi-rs/core": "^1.8.7",
		"@takumi-rs/helpers": "^1.8.7",
		"@takumi-rs/wasm": "^1.8.7",
		"@tanstack/react-virtual": "^3.14.3",
		"@types/d3": "^7.4.3",
		"better-auth": "^1.6.19",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "1.1.1",
		"d3": "^7.9.0",
		"ical-expander": "^3.2.0",
		"jimp": "^1.6.1",
		"js-yaml": "^4.2.0",
		"jszip": "^3.10.1",
		"kysely": "^0.29.2",
		"liquidjs": "^10.27.0",
		"lucide-react": "^1.21.0",
		"next": "16.2.9",
		"next-themes": "^0.4.6",
		"pg": "^8.21.0",
		"postgres": "^3.4.9",
		"puppeteer-core": "^25.1.0",
		"qrcode-generator": "^2.0.4",
		"radix-ui": "^1.6.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-virtuoso": "^4.18.7",
		"satori": "^0.26.0",
		"sharp": "0.34.5",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tailwindcss-animate": "^1.0.7",
		"zod": "^4.4.3",
		"zustand": "^5.0.14"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@eslint/eslintrc": "^3.3.5",
		"@tailwindcss/postcss": "^4.3.1",
		"@types/jest": "^30.0.0",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.9.3",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"baseline-browser-mapping": "^2.10.38",
		"eslint": "^9.39.4",
		"eslint-config-next": "16.2.9",
		"eslint-plugin-react-hooks": "^7.1.1",
		"jest": "^30.4.2",
		"kysely-codegen": "^0.20.0",
		"openapi-typescript": "^7.13.0",
		"shadcn": "^4.11.0",
		"tailwindcss": "^4.3.1",
		"ts-jest": "^29.4.11",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26"
}
